generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id                String           @id @default(cuid())
  ghlAgentId        String           @unique
  locationId        String
  agentName         String
  businessName      String
  agentPrompt       String           @db.Text
  welcomeMessage    String?          @db.Text
  actions           Json
  configHash        String?
  rubric            Json?
  rubricConfigHash  String?
  rubricGeneratedAt DateTime?
  agentAnalysis     Json?
  agentAnalysisInputHash String?
  agentAnalysisGeneratedAt DateTime?
  rawConfig         Json
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  callLogs          CallLog[]
  evaluations       CallEvaluation[]
}

model CallLog {
  id              String          @id @default(cuid())
  ghlCallId       String          @unique
  agentId         String
  contactId       String
  duration        Int
  transcript      String          @db.Text
  transcriptTurns Json
  summary         String          @db.Text
  executedActions Json
  extractedData   Json
  rawResponse     Json
  calledAt        DateTime
  createdAt       DateTime        @default(now())
  agent           Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  evaluation      CallEvaluation?
}

model CallEvaluation {
  id                   String   @id @default(cuid())
  callLogId            String   @unique
  agentId              String
  callPath             String?  @db.Text
  deterministicResults Json
  semanticResults      Json
  findings             Json
  outOfScopeItems      Json
  recommendations      Json
  overallScore         Float?
  evaluatedAt          DateTime
  createdAt            DateTime @default(now())
  callLog              CallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  agent                Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
}
